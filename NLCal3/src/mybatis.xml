<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE configuration PUBLIC "-//mybatis.org//DTD Config 3.0//EN" "http://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>

	<settings>
		<setting name="mapUnderscoreToCamelCase" value="true" />
	</settings>

	<typeAliases>
		<typeAlias alias="CalData" type="com.nlteck.model.CalData" />
		<typeAlias alias="TestData" type="com.nlteck.model.TestData" />
		<typeAlias alias="TestDot" type="com.nlteck.model.TestDot" />
		<typeAlias alias="TestLog" type="com.nlteck.model.TestLog" />
	</typeAliases>

	<environments default="development">
		<environment id="development">
			<transactionManager type="JDBC" />
			<dataSource type="POOLED">
				<property name="driver" value="com.mysql.jdbc.Driver" />
				<property name="url"
					value="jdbc:mysql://localhost:3306/cal?useUnicode=true&amp;characterEncoding=utf-8" />
				<property name="username" value="nlteck" />
				<property name="password" value="www.nlteck.com" />
			</dataSource>
		</environment>
	</environments>


	<mappers>
		<mapper resource="com/nlteck/model/mapper/CalDataMapper.xml" />
		<mapper resource="com/nlteck/model/mapper/TestDataMapper.xml" />
		<mapper resource="com/nlteck/model/mapper/TestDotMapper.xml" />
		<mapper resource="com/nlteck/model/mapper/TestLogMapper.xml" />
	</mappers>


</configuration>